{
    "name": "comentario-frontend",
    "version": "3.0.0",
    "private": true,
    "scripts": {
        "build": "ng build --configuration development && yarn run copy-assets && yarn run cleanup-assets",
        "build:prod": "ng build && yarn run copy-assets && yarn run cleanup-assets",
        "generate": "rm -rf generated-api/ && openapi-generator-cli generate -i ../resources/swagger/swagger.yml -g typescript-angular -o generated-api",
        "lint": "eslint",
        "start": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --browsers=ChromeHeadlessCI --watch=false --progress=false",
        "copy-assets": "cp ../build/frontend/en/*.ico ../build/frontend/en/*.png ../build/frontend/en/*.svg ../build/frontend/en/*.xml ../build/frontend/en/*.txt ../build/frontend/en/site.webmanifest ../build/frontend/",
        "cleanup-assets": "rm -f ../build/frontend/*/*.ico ../build/frontend/*/*.png ../build/frontend/*/*.svg ../build/frontend/*/*.xml ../build/frontend/*/*.txt ../build/frontend/*/site.webmanifest"
    },
    "dependencies": {
        "@angular/animations": "^20.0.6",
        "@angular/common": "^20.0.6",
        "@angular/compiler": "^20.0.6",
        "@angular/core": "^20.0.6",
        "@angular/forms": "^20.0.6",
        "@angular/localize": "^20.0.6",
        "@angular/platform-browser": "^20.0.6",
        "@angular/platform-browser-dynamic": "^20.0.6",
        "@angular/router": "^20.0.6",
        "@fortawesome/angular-fontawesome": "^2.0.1",
        "@fortawesome/fontawesome-svg-core": "^6.7.2",
        "@fortawesome/free-brands-svg-icons": "^6.7.2",
        "@fortawesome/free-regular-svg-icons": "^6.7.2",
        "@fortawesome/free-solid-svg-icons": "^6.7.2",
        "@ng-bootstrap/ng-bootstrap": "^19.0.1",
        "@ngneat/until-destroy": "^10.0.0",
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3.7",
        "chart.js": "^4.5.0",
        "ng2-charts": "^8.0.0",
        "ngx-highlightjs": "^14.0.1",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "~0.15.1"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^20.0.5",
        "@angular-devkit/core": "^20.0.5",
        "@angular-devkit/schematics": "^20.0.5",
        "@angular/cli": "^20.0.5",
        "@angular/compiler-cli": "^20.0.6",
        "@openapitools/openapi-generator-cli": "^2.21.0",
        "@types/jasmine": "^5.1.8",
        "angular-eslint": "^20.1.1",
        "jasmine-core": "^5.8.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.1.0",
        "ng-mocks": "^14.13.5",
        "vite": "^7.0.2"
    },
    "peerDependencies": {
        "@angular/cdk": "^20.0.5"
    }
}
