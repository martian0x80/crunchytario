{
    "name": "comentario-docs",
    "version": "3.0.0",
    "description": "Comentario documentation website",
    "private": true,
    "scripts": {
        "clean": "rm -rf ../build/docs/",
        "build": "yarn run clean && hugo -DF --gc --minify --environment=edge && yarn run write-headers",
        "build:prod": "yarn run clean && hugo --gc --minify --environment=production && yarn run write-headers",
        "start": "hugo server -DFO",
        "write-headers": "echo '/*\\n  Access-Control-Allow-Origin: *' > ../build/docs/_headers"
    },
    "devDependencies": {
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@popperjs/core": "^2.11.8",
        "bootstrap": "^5.3.7",
        "jquery": "^3.7.1"
    }
}
